{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Node16",
    "lib": ["ES2023", "DOM"],
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/backend/*"],
      "@lib/*": ["./lib/*"],
      "@config/*": ["./config/*"],
      "@utils/*": ["./utils/*"],
      "@security/*": ["./security/*"],
      "@monitoring/*": ["./monitoring/*"],
      "@middleware/*": ["./middleware/*"],
      "@test/*": ["./test/*"]
    }
  },
  "include": [
    "**/*.js",
    "**/*.mjs",
    "**/*.json",
    "lib/**/*",
    "config/**/*",
    "middleware/**/*",
    "security/**/*",
    "monitoring/**/*",
    "utils/**/*",
    "scripts/**/*",
    "test/**/*",
    "server.js"
  ],
  "exclude": [
    "node_modules/**",
    "coverage/**",
    "logs/**",
    "temp/**",
    "dist/**",
    "build/**",
    "**/*.min.js",
    "examples/**",
    "docs/**",
    "benchmarks/**"
  ],
  "watchOptions": {
    "watchFile": "useFsEvents",
    "watchDirectory": "useFsEvents",
    "fallbackPolling": "dynamicPriority",
    "synchronousWatchDirectory": true,
    "excludeDirectories": [
      "node_modules",
      "coverage",
      "logs",
      "temp",
      "dist",
      "build"
    ],
    "excludeFiles": [
      "**/*.min.js",
      "**/*.bundle.js"
    ]
  },
  "typeAcquisition": {
    "enable": true,
    "include": [
      "node"
    ],
    "exclude": []
  }
}