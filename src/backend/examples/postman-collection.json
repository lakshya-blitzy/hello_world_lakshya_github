    {
      "name": "Performance Testing",
      "description": "Requests configured for performance measurement, response time analysis, and load testing patterns",
      "item": [
        {
          "name": "Performance - Hello Endpoint Timing",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test response time measurement and analysis",
                  "pm.test(\"Response time under 100ms threshold\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(100);",
                  "});",
                  "",
                  "// Test successful response for performance baseline",
                  "pm.test(\"Successful response for performance test\", function () {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(pm.response.text()).to.equal('Hello world');",
                  "});",
                  "",
                  "// Measure and log performance metrics",
                  "pm.test(\"Performance metrics analysis\", function () {",
                  "    const responseTime = pm.response.responseTime;",
                  "    const contentLength = pm.response.headers.get('Content-Length');",
                  "    ",
                  "    console.log('Performance Metrics Analysis:');",
                  "    console.log(`- Response time: ${responseTime}ms`);",
                  "    console.log(`- Content length: ${contentLength || 'not specified'} bytes`);",
                  "    console.log(`- Performance rating: ${responseTime < 50 ? 'Excellent' : responseTime < 100 ? 'Good' : 'Acceptable'}`);",
                  "    ",
                  "    // Store performance data in collection variables",
                  "    pm.collectionVariables.set('lastResponseTime', responseTime);",
                  "    pm.collectionVariables.set('performanceTimestamp', new Date().toISOString());",
                  "});",
                  "",
                  "// Validate performance consistency",
                  "pm.test(\"Performance consistency check\", function () {",
                  "    const currentTime = pm.response.responseTime;",
                  "    const lastTime = pm.collectionVariables.get('lastResponseTime');",
                  "    ",
                  "    if (lastTime) {",
                  "        const variability = Math.abs(currentTime - lastTime);",
                  "        console.log(`Response time variability: ${variability}ms`);",
                  "        pm.expect(variability).to.be.below(200); // Allow 200ms variability",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
