    {
      "name": "Security Validation",
      "description": "Requests focused on security header validation, security testing, and web security best practices",
      "item": [
        {
          "name": "Security Headers - Hello Endpoint",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test X-Content-Type-Options security header",
                  "pm.test(\"X-Content-Type-Options header is nosniff\", function () {",
                  "    pm.expect(pm.response.headers.get('X-Content-Type-Options')).to.equal('nosniff');",
                  "});",
                  "",
                  "// Test X-Frame-Options security header",
                  "pm.test(\"X-Frame-Options header is DENY\", function () {",
                  "    pm.expect(pm.response.headers.get('X-Frame-Options')).to.equal('DENY');",
                  "});",
                  "",
                  "// Test Content-Type header accuracy",
                  "pm.test(\"Content-Type header is accurate\", function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('text/plain');",
                  "});",
                  "",
                  "// Comprehensive security header analysis",
                  "pm.test(\"Security header analysis\", function () {",
                  "    const headers = pm.response.headers;",
                  "    let securityScore = 0;",
                  "    const maxScore = 100;",
                  "    ",
                  "    console.log('Security Header Analysis:');",
                  "    ",
                  "    // X-Content-Type-Options analysis",
                  "    if (headers.get('X-Content-Type-Options') === 'nosniff') {",
                  "        securityScore += 30;",
                  "        console.log('✓ X-Content-Type-Options: nosniff (prevents MIME sniffing)');",
                  "    } else {",
                  "        console.log('✗ X-Content-Type-Options: missing or incorrect');",
                  "    }",
                  "    ",
                  "    // X-Frame-Options analysis",
                  "    if (headers.get('X-Frame-Options') === 'DENY') {",
                  "        securityScore += 30;",
                  "        console.log('✓ X-Frame-Options: DENY (prevents clickjacking)');",
                  "    } else {",
                  "        console.log('✗ X-Frame-Options: missing or incorrect');",
                  "    }",
                  "    ",
                  "    // Content-Type analysis",
                  "    if (headers.get('Content-Type')?.includes('text/plain')) {",
                  "        securityScore += 20;",
                  "        console.log('✓ Content-Type: properly specified');",
                  "    } else {",
                  "        console.log('✗ Content-Type: missing or incorrect');",
                  "    }",
                  "    ",
                  "    // Additional security headers check",
                  "    const additionalHeaders = ['X-XSS-Protection', 'Strict-Transport-Security', 'Content-Security-Policy'];",
                  "    additionalHeaders.forEach(header => {",
                  "        if (headers.get(header)) {",
                  "            securityScore += 5;",
                  "            console.log(`✓ ${header}: present`);",
                  "        }",
                  "    });",
                  "    ",
                  "    console.log(`Security Score: ${securityScore}/${maxScore}`);",
                  "    pm.collectionVariables.set('securityScore', securityScore);",
                  "});",
                  "",
                  "// Educational security analysis",
                  "pm.test(\"Educational security insights\", function () {",
                  "    console.log('Web Security Best Practices:');",
                  "    console.log('- X-Content-Type-Options prevents browsers from guessing content types');",
                  "    console.log('- X-Frame-Options prevents embedding in malicious frames');",
                  "    console.log('- Proper Content-Type prevents content type confusion');",
                  "    console.log('- Security headers provide defense-in-depth protection');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "User-Agent",
                "value": "{{userAgent}} (Security Test)",
                "description": "Security testing User-Agent"
              },
              {
                "key": "Accept",
                "value": "text/plain",
                "description": "Content preference for security testing"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/hello",
              "host": ["{{baseUrl}}"],
              "path": ["hello"]
            }
          },
          "response": []
        },
        {
          "name": "Security Headers - Health Endpoint",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test comprehensive security headers for health endpoint",
                  "pm.test(\"Security headers present on health endpoint\", function () {",
                  "    pm.expect(pm.response.headers.get('X-Content-Type-Options')).to.equal('nosniff');",
                  "    pm.expect(pm.response.headers.get('X-Frame-Options')).to.equal('DENY');",
                  "});",
                  "",
                  "// Test JSON content type security",
                  "pm.test(\"JSON Content-Type header is secure\", function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "// Security validation for sensitive health data",
                  "pm.test(\"Health endpoint security validation\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    ",
                  "    console.log('Health Endpoint Security Analysis:');",
                  "    console.log('- Endpoint exposes system information for monitoring');",
                  "    console.log('- Security headers protect against common attacks');",
                  "    console.log('- JSON content type properly specified');",
                  "    ",
                  "    // Check for potentially sensitive information exposure",
                  "    const sensitiveFields = ['password', 'secret', 'token', 'key'];",
                  "    const responseText = JSON.stringify(jsonData).toLowerCase();",
                  "    ",
                  "    sensitiveFields.forEach(field => {",
                  "        if (responseText.includes(field)) {",
                  "            console.log(`⚠ Potentially sensitive field detected: ${field}`);",
                  "        }",
                  "    });",
                  "    ",
                  "    console.log('- Health data appears properly sanitized');",
                  "});",
                  "",
                  "// Consistent security policy validation",
                  "pm.test(\"Consistent security policy across endpoints\", function () {",
                  "    const currentScore = pm.collectionVariables.get('securityScore') || 0;",
                  "    let healthSecurityScore = 0;",
                  "    ",
                  "    // Calculate security score for health endpoint",
                  "    if (pm.response.headers.get('X-Content-Type-Options') === 'nosniff') {",
                  "        healthSecurityScore += 30;",
                  "    }",
                  "    if (pm.response.headers.get('X-Frame-Options') === 'DENY') {",
                  "        healthSecurityScore += 30;",
                  "    }",
                  "    if (pm.response.headers.get('Content-Type')?.includes('application/json')) {",
                  "        healthSecurityScore += 20;",
                  "    }",
                  "    ",
                  "    console.log(`Health endpoint security score: ${healthSecurityScore}/100`);",
                  "    console.log('Security policy consistency: ' + (Math.abs(currentScore - healthSecurityScore) < 20 ? 'Good' : 'Needs review'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
