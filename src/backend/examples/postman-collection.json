            ],
            "url": {
              "raw": "{{baseUrl}}/invalid-endpoint",
              "host": ["{{baseUrl}}"],
              "path": ["invalid-endpoint"]
            }
          },
          "response": []
        },
        {
          "name": "405 Method Not Allowed - POST to Hello",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test appropriate 405 error status code",
                  "pm.test(\"Status code is 405 Method Not Allowed\", function () {",
                  "    pm.response.to.have.status(405);",
                  "});",
                  "",
                  "// Test Allow header presence for supported methods",
                  "pm.test(\"Allow header indicates supported methods\", function () {",
                  "    // Note: Server may or may not include Allow header",
                  "    const allowHeader = pm.response.headers.get('Allow');",
                  "    if (allowHeader) {",
                  "        pm.expect(allowHeader).to.include('GET');",
                  "    }",
                  "});",
                  "",
                  "// Educational analysis of 405 method not allowed error",
                  "pm.test(\"Educational 405 error analysis\", function () {",
                  "    console.log('405 Method Not Allowed Error Analysis:');",
                  "    console.log('- Error type: Client Error (4xx series)');",
                  "    console.log('- Meaning: HTTP method not supported for this endpoint');",
                  "    console.log('- Common causes: Using POST instead of GET, wrong HTTP verb');",
                  "    console.log('- Client handling: Use supported HTTP methods (GET for /hello)');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "User-Agent",
                "value": "{{userAgent}}",
                "description": "User-Agent for method not allowed testing"
