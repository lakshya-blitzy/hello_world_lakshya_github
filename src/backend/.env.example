# =============================================================================
# Node.js Tutorial HTTP Server - Environment Configuration Template
# =============================================================================
# This file serves as a comprehensive template for environment variable 
# configuration in Node.js applications. Copy this file to .env and modify 
# values according to your deployment environment.
# 
# IMPORTANT SECURITY NOTES:
# - Never commit .env files containing sensitive data to version control
# - Use this .env.example file for documentation and team collaboration
# - Restart the HTTP server after modifying environment variables
# - Different environments (development/production/test) require different settings
# =============================================================================

# =============================================================================
# APPLICATION ENVIRONMENT
# =============================================================================
# Controls core application behavior, logging levels, and environment-specific
# configuration defaults throughout the application lifecycle.
# 
# Supported values: development | production | test
# - development: Enables debug logging, detailed error traces, request logging
# - production: Optimized for performance, minimal logging, secure error handling  
# - test: Minimal logging, fast execution, isolated testing environment
NODE_ENV=development

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# HTTP server network interface binding and connection management settings.
# These variables control how the server listens for incoming connections
# and manages client communication.

# Server listening port - must use non-privileged ports (1024-65535)
# Port 3000 is commonly used for development, 80/443 for production
# Use PORT=0 for automatic port assignment (useful for testing)
PORT=3000

# Server hostname/IP address binding configuration
# 127.0.0.1 (localhost) - restricts access to local machine only
# 0.0.0.0 (all interfaces) - allows external connections (use with caution)
# Specific IP addresses can be used for targeted network interface binding
HOST=127.0.0.1

# Alternative hostname configuration (fallback when HOST is not specified)
# This provides compatibility with different deployment environments
# that may use HOSTNAME instead of HOST for server binding
HOSTNAME=localhost

# Maximum concurrent HTTP connections the server will accept
# Development: 100 (sufficient for testing and learning)
# Production: 1000+ (adjust based on expected load and server resources)
# Too high values can exhaust server resources, too low limits throughput
MAX_CONNECTIONS=100

# Individual HTTP connection timeout in milliseconds
# Controls how long idle connections remain open before automatic closure
# 30 seconds (30000ms) is a balanced default for most applications
CONNECTION_TIMEOUT=30000

# =============================================================================
# REQUEST HANDLING CONFIGURATION
# =============================================================================
# HTTP request processing timeouts and performance settings that control
# how the server handles incoming requests and prevents resource exhaustion.

# Complete HTTP request processing timeout in milliseconds
# Total time allowed for processing any single HTTP request
# 2 minutes (120000ms) accommodates most processing scenarios
TIMEOUT=120000

# HTTP keep-alive connection timeout for persistent connections
# Time to maintain connections between requests for better performance
# 5 seconds (5000ms) balances performance with resource usage
KEEP_ALIVE_TIMEOUT=5000

# Maximum time for receiving complete HTTP request headers
# Prevents slowloris and similar slow-header attacks
# 1 minute (60000ms) is sufficient for normal client behavior
HEADERS_TIMEOUT=60000

# Complete request timeout including headers and body processing
# Overall time limit for receiving and processing entire HTTP requests
# 5 minutes (300000ms) accommodates larger request processing
REQUEST_TIMEOUT=300000

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Application logging behavior and output destination settings.
# Proper logging is essential for debugging, monitoring, and security auditing.

# Logging verbosity level - controls which messages are displayed
# debug: All messages (verbose, for development)
# info: Informational messages and above (recommended for production)
# warn: Warning messages and above (errors and warnings only)
# error: Error messages only (minimal logging)
LOG_LEVEL=info

# Enable or disable console/terminal log output
# true: Display log messages in console/terminal (useful for development)
# false: Suppress console output (useful when using file-only logging)
ENABLE_CONSOLE_LOGGING=true

# Enable or disable file-based logging output
# true: Write log messages to specified log files
# false: No file logging (console only or no logging)
ENABLE_FILE_LOGGING=false

# Log file path when file logging is enabled
# Uncomment and specify path when ENABLE_FILE_LOGGING=true
# Ensure the directory exists and has write permissions
# Example: logs/application.log, /var/log/tutorial-server.log
# LOG_FILE=logs/application.log

# =============================================================================
# DEVELOPMENT AND DEBUGGING
# =============================================================================
# Enhanced development experience and debugging settings.
# These options provide additional visibility for troubleshooting and learning.

# Enable detailed HTTP request logging for debugging and monitoring
# true: Log each HTTP request with method, path, status, and timing
# false: No individual request logging (reduces log verbosity)
# Recommended: true for development, false for production
ENABLE_REQUEST_LOGGING=true

# Include full error stack traces in error logging output
# true: Show complete error stack traces for debugging
# false: Generic error messages without technical details
# SECURITY WARNING: Disable in production to prevent information disclosure
ENABLE_ERROR_STACK_TRACES=true

# =============================================================================
# USAGE INSTRUCTIONS
# =============================================================================
# 1. SETUP ENVIRONMENT:
#    Copy this template: cp .env.example .env
#    
# 2. CONFIGURE VALUES:
#    Edit .env file with environment-specific values
#    
# 3. RESTART SERVER:
#    Server must be restarted to load new environment variables
#    Command: npm start or node server.js
#    
# 4. VERIFY CONFIGURATION:
#    Check server startup logs for loaded configuration values
#    Access http://localhost:3000/hello to test functionality

# =============================================================================
# ENVIRONMENT-SPECIFIC EXAMPLES
# =============================================================================

# DEVELOPMENT ENVIRONMENT EXAMPLE:
# NODE_ENV=development
# PORT=3000
# HOST=127.0.0.1
# LOG_LEVEL=debug
# ENABLE_CONSOLE_LOGGING=true
# ENABLE_REQUEST_LOGGING=true
# ENABLE_ERROR_STACK_TRACES=true

# PRODUCTION ENVIRONMENT EXAMPLE:
# NODE_ENV=production
# PORT=3000
# HOST=0.0.0.0
# LOG_LEVEL=info
# ENABLE_CONSOLE_LOGGING=true
# ENABLE_FILE_LOGGING=true
# LOG_FILE=logs/production.log
# ENABLE_REQUEST_LOGGING=false
# ENABLE_ERROR_STACK_TRACES=false
# MAX_CONNECTIONS=1000

# TEST ENVIRONMENT EXAMPLE:
# NODE_ENV=test
# PORT=0
# HOST=127.0.0.1
# LOG_LEVEL=error
# ENABLE_CONSOLE_LOGGING=false
# ENABLE_FILE_LOGGING=false
# TIMEOUT=5000
# KEEP_ALIVE_TIMEOUT=1000

# =============================================================================
# SECURITY BEST PRACTICES
# =============================================================================
# 1. FILE PERMISSIONS:
#    - Set restrictive permissions on .env files (chmod 600 .env)
#    - Never commit .env files to version control systems
#    
# 2. NETWORK SECURITY:
#    - Use 127.0.0.1 for development (localhost only)
#    - Carefully configure HOST=0.0.0.0 for production (all interfaces)
#    - Consider firewall rules when binding to all interfaces
#    
# 3. PRODUCTION HARDENING:
#    - Disable debug features (stack traces, verbose logging)
#    - Use appropriate timeout values to prevent DoS attacks
#    - Enable file logging with log rotation for audit trails
#    - Monitor connection limits to prevent resource exhaustion
#    
# 4. INFORMATION DISCLOSURE:
#    - Set ENABLE_ERROR_STACK_TRACES=false in production
#    - Use generic error messages for client responses
#    - Implement proper error logging for internal debugging

# =============================================================================
# VALIDATION RULES AND CONSTRAINTS
# =============================================================================
# PORT: Integer between 1024-65535 (non-privileged ports)
# HOST: Valid IPv4 address, IPv6 address, or resolvable hostname
# NODE_ENV: Must be one of: development, production, test
# LOG_LEVEL: Must be one of: debug, info, warn, error
# TIMEOUT VALUES: Positive integers in milliseconds
# BOOLEAN VALUES: Must be 'true' or 'false' (case-sensitive)
# MAX_CONNECTIONS: Positive integer within system resource limits

# =============================================================================
# INTEGRATION WITH APPLICATION
# =============================================================================
# These environment variables are processed by:
# - config/environment.js: Validates and loads environment configuration
# - config/server-config.js: Merges with static server configuration
# - server.js: Main application entry point consumes final configuration
# 
# Configuration precedence (highest to lowest):
# 1. System environment variables
# 2. .env file values
# 3. Application default values
# 
# Template version: 1.0.0
# Compatible Node.js versions: 18.x, 20.x, 22.x
# Last updated: For Node.js Tutorial HTTP Server educational project
# =============================================================================