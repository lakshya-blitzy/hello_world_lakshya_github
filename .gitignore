# Python Flask Migration .gitignore
# This file prevents Python development artifacts, virtual environments,
# and build files from being committed to the repository.

# ================================
# Python-specific patterns
# ================================

# Bytecode / compiled Python files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ================================
# Virtual environments
# ================================

# Flask project virtual environment
flask_env/

# Common virtual environment names
venv/
env/
ENV/
env.bak/
venv.bak/

# pipenv
Pipfile.lock

# poetry
poetry.lock

# ================================
# Flask-specific patterns
# ================================

# Flask instance folder
instance/

# Flask-specific cache
.flask_cache/

# Werkzeug cache
.werkzeug-cache/

# ================================
# Development tools
# ================================

# IDE configurations
.vscode/
.idea/
*.swp
*.swo
*~

# Sublime Text
*.sublime-workspace
*.sublime-project

# PyCharm
.idea/

# VS Code
.vscode/

# ================================
# Testing and coverage
# ================================

# pytest
.pytest_cache/
.cache/

# Coverage reports
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
*.py,cover
.hypothesis/

# tox
.tox/

# ================================
# OS-specific files
# ================================

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Windows
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ================================
# Development artifacts
# ================================

# Logs
*.log
logs/

# Database files
*.db
*.sqlite
*.sqlite3

# Temporary files
*.tmp
*.temp
.tmp/

# Environment variables
.env
.env.local
.env.*.local

# ================================
# Legacy Node.js compatibility
# ================================
# Keep these for rollback capability

# Node.js dependencies
node_modules/

# NPM
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Package lock files
package-lock.json
yarn.lock

# ================================
# Documentation build artifacts
# ================================

# Sphinx documentation
docs/_build/
docs/build/

# MkDocs
site/

# ================================
# Security and secrets
# ================================

# Local configuration files
config.local.py
settings.local.py

# SSL certificates
*.pem
*.key
*.crt
*.csr

# API keys and secrets
secrets.py
.secrets/

# ================================
# Production deployment
# ================================

# WSGI server logs
gunicorn.log
uwsgi.log

# Static files collection (if used)
staticfiles/
static_root/

# Media files (if used)
media/
uploads/